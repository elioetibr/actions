{
  "name": "actions",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <26.0.0"
  },
  "description": "GitHub Actions",
  "main": "src/index.ts",
  "author": "Elio Severo Junior <elio@elio.eti.br>",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "clean": "rm -rf ./dist",
    "clean-all": "rm -rf ./coverage ./dist ./node_modules",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint --no-warn-ignored src/**/*.ts",
    "lint:fix": "eslint --no-warn-ignored --fix src/**/*.ts",
    "lint:tsc": "tsc --noEmit",
    "report-coverage": "bun test --coverage --coverage-reporter=text",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "update-readme": "ts-node scripts/updateReadme.ts"
  },
  "keywords": [
    "github",
    "actions",
    "docker",
    "tags"
  ],
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@docker/actions-toolkit": "^0.87.0",
    "@linear/sdk": "^81.0.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "@octokit/request": "^10.0.8",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "jira.js": "^5.3.1",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "packageManager": "bun@1.3.11",
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "trustedDependencies": [
    "esbuild",
    "unrs-resolver"
  ],
  "overrides": {
    "@octokit/plugin-paginate-rest@>=1.0.0 <9.2.2": ">=9.2.2",
    "@octokit/request-error@>=1.0.0 <5.1.1": ">=5.1.1",
    "@octokit/request@>=1.0.0 <8.4.1": ">=8.4.1",
    "esbuild@<=0.24.2": ">=0.25.0",
    "undici@<6.23.0": ">=6.23.0"
  }
}
