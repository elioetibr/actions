{
  "name": "actions",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.0"
  },
  "description": "GitHub Actions",
  "main": "src/index.ts",
  "author": "Elio Severo Junior <elio@elio.eti.br>",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "clean": "rm -rf dist",
    "clean-all": "rm -rf ./coverage ./dist ./node_modules",
    "deps": "bunx --bun npm-check-updates -u --target minor && bun install",
    "deps:check": "bunx --bun npm-check-updates --target minor",
    "deps:latest": "bunx --bun npm-check-updates -u --target latest && bun install",
    "format:check": "prettier --check **/*.ts",
    "format:fix": "prettier --write **/*.ts",
    "fix:all": "bun run lint:fix && bun run format:fix",
    "lint": "eslint --no-warn-ignored --max-warnings 0 **/*.ts",
    "lint:fix": "eslint --no-warn-ignored --fix --max-warnings 0 **/*.ts",
    "lint:tsc": "tsc --noEmit",
    "prepare": "husky",
    "test": "bun scripts/test-isolated.ts",
    "test:bun": "bun test",
    "test:coverage": "bun scripts/test-isolated.ts --coverage",
    "test:coverage:lcov": "bun test --coverage-reporter=lcov",
    "test:coverage:report": "bun scripts/test-isolated.ts --coverage",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "update": "bun update"
  },
  "keywords": [
    "github",
    "actions",
    "docker",
    "tags"
  ],
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@docker/actions-toolkit": "^0.90.0",
    "@linear/sdk": "^81.0.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "@octokit/request": "^10.0.9",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "jira.js": "^5.3.1",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "trustedDependencies": [
    "esbuild",
    "unrs-resolver"
  ],
  "overrides": {
    "@octokit/plugin-paginate-rest@>=1.0.0 <9.2.2": ">=9.2.2",
    "@octokit/request-error@>=1.0.0 <5.1.1": ">=5.1.1",
    "@octokit/request@>=1.0.0 <8.4.1": ">=8.4.1",
    "esbuild@<=0.24.2": ">=0.25.0",
    "undici@<6.23.0": ">=6.23.0"
  }
}
